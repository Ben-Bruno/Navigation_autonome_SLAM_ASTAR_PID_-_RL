      <visual name="visual"><geometry><cylinder><radius>0.4</radius><length>1</length></cylinder></geometry><material><script><name>Gazebo/Blue</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material></visual></link></model>

    <!-- Edge obstacles: long low boxes parallel to walls to create corridors -->
    <model name="edge_north_strip_1"><static>1</static><pose>-4 7.2 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>3 0.2 0.5</size></box></geometry><max_contacts>10</max_contacts></collision>
      <visual name="visual"><geometry><box><size>3 0.2 0.5</size></box></geometry><material><script><name>Gazebo/DarkGrey</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material></visual></link></model>

    <model name="edge_north_strip_2"><static>1</static><pose>4 7.2 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>3 0.2 0.5</size></box></geometry><max_contacts>10</max_contacts></collision>
