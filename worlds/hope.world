      <link name="link"><collision name="collision"><geometry><cylinder><radius>0.3</radius><length>1</length></cylinder></geometry><max_contacts>10</max_contacts></collision>
      <visual name="visual"><geometry><cylinder><radius>0.3</radius><length>1</length></cylinder></geometry><material><script><name>Gazebo/Blue</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material></visual></link></model>

    <model name="col_ring_10"><static>1</static><pose>2.5 -4.3301 0.5 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><cylinder><radius>0.3</radius><length>1</length></cylinder></geometry><max_contacts>10</max_contacts></collision>
      <visual name="visual"><geometry><cylinder><radius>0.3</radius><length>1</length></cylinder></geometry><material><script><name>Gazebo/Blue</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material></visual></link></model>

    <model name="col_ring_11"><static>1</static><pose>4.3301 -2.5 0.5 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><cylinder><radius>0.3</radius><length>1</length></cylinder></geometry><max_contacts>10</max_contacts></collision>
      <visual name="visual"><geometry><cylinder><radius>0.3</radius><length>1</length></cylinder></geometry><material><script><name>Gazebo/Blue</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material></visual></link></model>

    <!-- Additional dense obstacle clusters near corners and edges but outside center -->
    <!-- Cluster NE: mix of boxes and cylinders -->
    <model name="cluster_ne_box_1"><static>1</static><pose>7 6 0.5 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.8 0.8 1</size></box></geometry><max_contacts>10</max_contacts></collision>
      <visual name="visual"><geometry><box><size>0.8 0.8 1</size></box></geometry><material><script><name>Gazebo/Red</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material></visual></link></model>

    <model name="cluster_ne_box_2"><static>1</static><pose>6 7 0.5 0 0 0</pose>
