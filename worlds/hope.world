    <model name="rand_box_4"><static>1</static><pose>-3.8 -5.5 0.5 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.6 0.6 1</size></box></geometry><max_contacts>10</max_contacts></collision>
      <visual name="visual"><geometry><box><size>0.6 0.6 1</size></box></geometry><material><script><name>Gazebo/Yellow</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material></visual></link></model>

    <!-- Tall pillar obstacles near corners to vary heights -->
    <model name="tall_pillar_ne"><static>1</static><pose>7.5 7.5 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><cylinder><radius>0.5</radius><length>2</length></cylinder></geometry><max_contacts>10</max_contacts></collision>
      <visual name="visual"><geometry><cylinder><radius>0.5</radius><length>2</length></cylinder></geometry><material><script><name>Gazebo/Brown</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material></visual></link></model>

    <model name="tall_pillar_nw"><static>1</static><pose>-7.5 7.5 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><cylinder><radius>0.5</radius><length>2</length></cylinder></geometry><max_contacts>10</max_contacts></collision>
      <visual name="visual"><geometry><cylinder><radius>0.5</radius><length>2</length></cylinder></geometry><material><script><name>Gazebo/Brown</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material></visual></link></model>

    <model name="tall_pillar_se"><static>1</static><pose>7.5 -7.5 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><cylinder><radius>0.5</radius><length>2</length></cylinder></geometry><max_contacts>10</max_contacts></collision>
      <visual name="visual"><geometry><cylinder><radius>0.5</radius><length>2</length></cylinder></geometry><material><script><name>Gazebo/Brown</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material></visual></link></model>

    <model name="tall_pillar_sw"><static>1</static><pose>-7.5 -7.5 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><cylinder><radius>0.5</radius><length>2</length></cylinder></geometry><max_contacts>10</max_contacts></collision>
      <visual name="visual"><geometry><cylinder><radius>0.5</radius><length>2</length></cylinder></geometry><material><script><name>Gazebo/Brown</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material></visual></link></model>

    <!-- Ensure robot spawn area remains clear: add a visual marker (optional) but no collisions inside radius 4.5 -->
    <model name="spawn_marker" >
      <static>1</static>
      <pose>0 0 0.01 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><cylinder><radius>4.5</radius><length>0.02</length></cylinder></geometry>
          <material><script><name>Gazebo/Transparent</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material>
          <cast_shadows>0</cast_shadows>
        </visual>
      </link>
    </model>

    <!-- End of world -->
  </world>
</sdf>
