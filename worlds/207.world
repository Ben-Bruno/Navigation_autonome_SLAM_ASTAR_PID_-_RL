    <!-- ═══════════════════════════════════════════════════
         OBSTACLES RECTANGULAIRES — Boîtes dans les couloirs
         Pour forcer le robot à naviguer autour
         ═══════════════════════════════════════════════ -->

    <!-- Boîtes dans couloir Nord (entre y=4 et y=10, x proche 0) -->
    <model name="box_corridor_n1">
      <static>1</static>
      <pose>2.5 7 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>0.6 0.6 1</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.6 0.6 1</size></box></geometry>
          <material><script>
            <uri>file://media/materials/scripts/gazebo.material</uri>
