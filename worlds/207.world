          </script></material>
        </visual>
      </link>
    </model>

    <!-- Cloison verticale Est (x=5, de y=-2 à y=2) — couloir central -->
    <model name="wall_int_e_v">
      <static>1</static>
      <pose>5 0 1 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>0.2 4 2</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.2 4 2</size></box></geometry>
          <material><script>
            <uri>file://media/materials/scripts/gazebo.material</uri>
            <name>Gazebo/Grey</name>
          </script></material>
        </visual>
      </link>
    </model>

    <!-- Cloison verticale Ouest (x=-5, de y=-2 à y=2) — couloir central -->
    <model name="wall_int_w_v">
      <static>1</static>
      <pose>-5 0 1 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>0.2 4 2</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.2 4 2</size></box></geometry>
          <material><script>
            <uri>file://media/materials/scripts/gazebo.material</uri>
            <name>Gazebo/Grey</name>
          </script></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════
         OBSTACLES CYLINDRIQUES
         Colonnes slim (r=0.25) dispersées dans les salles
         Toutes à >4 m du spawn, espacées >1.5 m entre elles
         ═══════════════════════════════════════════════ -->

    <!-- Salle Nord-Est -->
    <model name="col_ne_a">
      <static>1</static>
      <pose>7 7 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><cylinder><radius>0.25</radius><length>1</length></cylinder></geometry>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.25</radius><length>1</length></cylinder></geometry>
          <material><script>
